{
  "expo": {
    "name": "PixelLoad",
    "slug": "PixelLoadV2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pixelload",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,

    "android": {
      "package": "com.visionpixels.pixelload",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#03040A"
      }
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.visionpixels.pixelload"
    },

    "web": {
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "eas": {
        "projectId": "970a7866-123a-4999-9695-73a9cea22231"
      }
    }
  }
}